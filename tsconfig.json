{
  "compilerOptions": {
    "strict": true,
    "module": "nodenext",
    "outDir": "dist",
    "rootDir": "src",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["./src/**/*"],
  "exclude": ["src/test"],
  "ts-node": {
    "esm": true
  }
}
