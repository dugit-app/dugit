{
  "compilerOptions": {
    "strict": true,
    "module": "nodenext",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*"],
  "exclude": [
    "node_modules",
    "src/test"
  ],
  "ts-node": {
    "esm": true
  }
}
